{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntentMessage",
  "type": "object",
  "required": ["role", "type", "trace_id", "payload"],
  "properties": {
    "role": { "type": "string", "enum": ["user", "system"] },
    "type": { "type": "string", "const": "intent" },
    "trace_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["text"],
      "properties": { "text": { "type": "string" } }
    }
  }
}
